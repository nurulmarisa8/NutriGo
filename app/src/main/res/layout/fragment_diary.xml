<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Diary Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Food Diary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/btnPrevDate"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Hari Sebelumnya"
                app:tint="@color/green_primary"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Today"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

            <ImageButton
                android:id="@+id/btnNextDate"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_next"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Hari Selanjutnya"
                app:tint="@color/green_primary"/>
        </LinearLayout>

        <!-- ── Calorie Summary Card ── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <!-- Calorie ring -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progressCalories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:progress="60"
                        app:indicatorSize="160dp"
                        app:trackThickness="14dp"
                        app:indicatorColor="@color/green_primary"
                        app:trackColor="@color/green_extra_light"
                        app:trackCornerRadius="8dp" />

                    <LinearLayout
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvCaloriesEaten"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="34sp"
                            android:textStyle="bold"
                            android:textColor="@color/green_primary" />

                        <TextView
                            android:id="@+id/tvCaloriesGoal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="/ 2,000"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories Eaten"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp" />

                <!-- Remaining budget -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Remaining Budget"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvRemainingBudget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2000 kcal"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/green_primary" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Protein bar -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                        android:text="Protein" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <ProgressBar
                        android:id="@+id/progressProtein"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:progressDrawable="@drawable/progress_protein"
                        android:max="100"
                        android:progress="0" />
                    <TextView
                        android:id="@+id/tvProteinValue"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="0g / 120g"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Carbs bar -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                        android:text="Carbs" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <ProgressBar
                        android:id="@+id/progressCarbs"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:progressDrawable="@drawable/progress_carbs"
                        android:max="100"
                        android:progress="0" />
                    <TextView
                        android:id="@+id/tvCarbsValue"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="0g / 220g"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="end"/>
                </LinearLayout>

                <!-- Fat bar -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                        android:text="Fat" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <ProgressBar
                        android:id="@+id/progressFat"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:progressDrawable="@drawable/progress_fat"
                        android:max="100"
                        android:progress="0" />
                    <TextView
                        android:id="@+id/tvFatValue"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="0g / 65g"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="end"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Today's Meals header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Today's Meals"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <!-- ── Meal list ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewMeals"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- Empty state -->
        <LinearLayout
            android:id="@+id/tvEmptyDiary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥗"
                android:textSize="48sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum ada makanan hari ini"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cari resep di tab Search dan simpan ke jurnal"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Bottom padding -->
        <View android:layout_width="match_parent" android:layout_height="16dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
